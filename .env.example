NODE_ENV=development
PORT=4002

# Conexion local
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=finanbotai_db

# Alternativa: cadena unica (sobreescribe PG* si esta presente)
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/finanbotai_db
PGSSL=false

# JWT
JWT_FIRMA=cambia_este_secreto_por_64_caracteres_aleatorios
JWT_DURACION_ACCESO=15m
REFRESH_DURACION_DIAS=30

# Google Gemini (clave necesaria para diagnostico IA)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Decolecta (tipo de cambio SBS)
DECOLECTA_API_TOKEN=
DECOLECTA_BASE_URL=https://api.decolecta.com

# SMTP (recuperacion de contrasena)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="FinanBotAI <noreply@finanbotai.pe>"

# Deep link de la app movil para reestablecer contrasena
APP_FRONTEND_URL=finanbotai://restablecer
